generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  role         UserRole      @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  machineRates  MachineRate[]
  manualEntries ManualEntry[]
  ticketFixCosts TicketFixCost[]
  assetsUpdated Asset[]      @relation("AssetUpdatedBy")
}

model Asset {
  id             String        @id @default(cuid())
  machineKey      String        @unique
  category        String
  subcategory     String
  model           String?
  serialNumber    String?
  manufacturer    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  updatedById     String?
  updatedBy       User?         @relation("AssetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  machineRate     MachineRate?
  manualEntries   ManualEntry[]
  ticketFixCosts  TicketFixCost[]
  plannedMaintenances PlannedMaintenance[]
}

model MachineRate {
  id          String   @id @default(cuid())
  machineKey  String   @unique
  hourlyRate  Float    @default(0)
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  asset       Asset    @relation(fields: [machineKey], references: [machineKey], onDelete: Restrict)
}

model ManualEntry {
  id          String   @id @default(cuid())
  machineKey  String
  date        String
  amount      Float
  comment     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  asset       Asset    @relation(fields: [machineKey], references: [machineKey], onDelete: Restrict)

  @@index([machineKey])
  @@index([date])
}

model TicketFixCost {
  id          String   @id @default(cuid())
  issueKey    String   @unique
  machineKey  String
  date        String
  amount      Float
  comment     String
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  asset       Asset    @relation(fields: [machineKey], references: [machineKey], onDelete: Restrict)

  @@index([machineKey])
  @@index([date])
}

model PlannedMaintenance {
  id           String   @id @default(cuid())
  machineKey   String
  title        String
  dueDate      DateTime
  note         String?
  cost         Float?
  jiraIssueId  String?
  jiraIssueKey String?
  jiraIssueUrl String?
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  asset        Asset    @relation(fields: [machineKey], references: [machineKey], onDelete: Restrict)

  @@index([machineKey])
  @@index([dueDate])
  @@index([isCompleted])
  @@index([jiraIssueKey])
}
